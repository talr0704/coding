// ── Firebase Storage Security Rules ─────────────────────────────────────────
// Paste these rules into:
//   Firebase Console → Storage → Rules
// ─────────────────────────────────────────────────────────────────────────────

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Users can only read/write files inside their own folder.
    // Path pattern:  users/{userId}/projects/{projectId}/{filename}
    match /users/{userId}/{allPaths=**} {

      // Allow authenticated users to read their own files (no size/type check on reads).
      allow read: if request.auth != null
                  && request.auth.uid == userId;

      // Writes: authenticated owner only, images only, max 1 MB.
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size <= 1 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Deny everything else.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
