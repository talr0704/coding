// ── Firebase Storage Security Rules ─────────────────────────────────────────
// Paste these rules into:
//   Firebase Console → Storage → Rules
// ─────────────────────────────────────────────────────────────────────────────

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Users can only read/write files inside their own folder.
    // Path pattern:  users/{userId}/projects/{projectId}/{filename}
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId
                         && request.resource.size < 5 * 1024 * 1024   // max 5 MB per file
                         && request.resource.contentType.matches('image/.*');  // images only
    }

    // Allow reads without size/type restriction (download existing files).
    match /users/{userId}/{allPaths=**} {
      allow read: if request.auth != null
                  && request.auth.uid == userId;
    }

    // Deny everything else.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
