// ── Firebase Storage Security Rules ─────────────────────────────────────────
// Paste these rules into:
//   Firebase Console → Storage → Rules
// ─────────────────────────────────────────────────────────────────────────────

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Project images: public read so bgpic() / shape() can load them in the
    // browser without authentication (the file path already contains the userId
    // and projectId, so URLs are not guessable without knowing those IDs).
    // Writes remain strictly owner-only, images-only, max 1 MB.
    match /users/{userId}/projects/{projectId}/{filename} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size <= 1 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Deny everything else.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
