// ── Firestore Security Rules ─────────────────────────────────────────────────
// Paste these rules into:
//   Firebase Console → Firestore Database → Rules
// ─────────────────────────────────────────────────────────────────────────────

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Private projects ── owner-only read + write ───────────────────────────
    match /users/{userId}/projects/{projectId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Public preview snapshots ──────────────────────────────────────────────
    // Anyone can read (no login required).
    // Only the project owner may create, update, or delete the snapshot.
    // Ownership is verified via cross-document check: the caller must own the
    // private project whose ID is stored in the snapshot's projectId field.
    match /publicProjects/{publicId} {
      allow read: if true;

      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(["title","type","code","images","projectId","publishedAt"])
        && exists(/databases/$(database)/documents/users/$(request.auth.uid)/projects/$(request.resource.data.projectId));

      allow update: if request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid)/projects/$(resource.data.projectId));

      allow delete: if request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid)/projects/$(resource.data.projectId));
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
